rate_limit:
  enabled: true
  default_rpm: 60
  default_tpm: 100000

metrics:
  enabled: true
  path: "/metrics"

log:
  level: "info"
  format: "json"

payment:
  stripe:
    secret_key: "sk_test_your_stripe_secret_key"
    webhook_secret: "whsec_your_webhook_secret"
  alipay:
    app_id: ""
    private_key: ""
  wechat:
    app_id: ""
    mch_id: ""
    api_key: ""

routing:
  mode: "fallback"
  health_check:
    window: "5m"
    error_threshold: 5

retry:
  max_attempts: 3
  initial_backoff: "200ms"
  max_backoff: "5s"
  backoff_multiplier: 2.0

circuit_breaker:
  failure_threshold: 5
  success_threshold: 2
  timeout: "30s"
  window: "60s"
