# Configuration template - copy to config.yaml and fill in real values

server:
  host: "0.0.0.0"
  port: 8080
  read_timeout: 30
  write_timeout: 60
  idle_timeout: 120

database:
  host: "your-database-host.neon.tech"
  port: 5432
  user: "your_db_user"
  password: "your_db_password"
  dbname: "your_db_name"
  sslmode: require
  extra_params: "channel_binding=require"
  max_conns: 10
  min_conns: 2

redis:
  addr: ${HI_AI_REDIS_ADDR:-localhost:6379}
  password: ${HI_AI_REDIS_PASSWORD:-}
  db: 0

auth:
  jwt_secret: "your-jwt-secret-here-change-in-production"
  access_token_ttl: 3600
  refresh_token_ttl: 604800

